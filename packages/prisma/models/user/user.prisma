model User {
  id    Int    @id @default(autoincrement())
  email String @unique
  description String?
  createdAt DateTime @default(now())

  products Product[]
}

model Product {
  id    Int    @id @default(autoincrement())
  name String
  description String?
  createdAt DateTime @default(now())

  userId Int
  user User @relation(fields: [userId], references: [id])
}